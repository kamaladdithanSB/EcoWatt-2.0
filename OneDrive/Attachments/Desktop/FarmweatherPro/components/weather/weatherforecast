
import React from "react";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { format, parseISO, isValid } from "date-fns";
import { 
  CloudRain, 
  Cloud, 
  Sun, 
  CloudSnow,
  Zap
} from "lucide-react";

export default function WeatherForecast({ forecast }) {
  if (!forecast || forecast.length === 0) return null;

  const getWeatherIcon = (conditions) => {
    const condition = conditions.toLowerCase();
    if (condition.includes('rain') || condition.includes('shower')) return CloudRain;
    if (condition.includes('snow')) return CloudSnow;
    if (condition.includes('storm') || condition.includes('thunder')) return Zap;
    if (condition.includes('cloud')) return Cloud;
    return Sun;
  };

  const getIconColor = (conditions) => {
    const condition = conditions.toLowerCase();
    if (condition.includes('rain') || condition.includes('shower')) return "text-blue-600";
    if (condition.includes('snow')) return "text-gray-400";
    if (condition.includes('storm') || condition.includes('thunder')) return "text-purple-600";
    if (condition.includes('cloud')) return "text-gray-600";
    return "text-yellow-600";
  };

  const formatDate = (dateString, index) => {
    try {
      if (!dateString) return index === 0 ? 'Today' : `Day ${index + 1}`;
      
      // Try to parse the date
      let date;
      // parseISO is generally preferred for ISO 8601 strings,
      // but new Date() can handle more general formats.
      // We try parseISO first as it's more specific for common API date formats.
      if (typeof dateString === 'string' && (dateString.includes('T') || dateString.includes('-'))) {
        date = parseISO(dateString);
      } else {
        date = new Date(dateString);
      }
      
      if (isValid(date)) {
        return index === 0 ? 'Today' : format(date, 'EEEE');
      }
      
      // Fallback if date is invalid
      return index === 0 ? 'Today' : `Day ${index + 1}`;
    } catch (error) {
      console.warn('Date formatting error:', error);
      return index === 0 ? 'Today' : `Day ${index + 1}`;
    }
  };

  return (
    <Card className="shadow-xl border-0 bg-white/80 backdrop-blur-sm">
      <CardHeader>
        <CardTitle className="text-gray-900">7-Day Forecast</CardTitle>
      </CardHeader>
      <CardContent>
        <div className="space-y-3">
          {forecast.slice(0, 7).map((day, index) => {
            // Provide default 'clear' for conditions if undefined
            const currentConditions = day.conditions || 'clear';
            const IconComponent = getWeatherIcon(currentConditions);
            const iconColor = getIconColor(currentConditions);
            
            return (
              <div
                key={index}
                className="flex items-center justify-between p-4 rounded-lg bg-gradient-to-r from-green-50 to-blue-50 hover:from-green-100 hover:to-blue-100 transition-all duration-200"
              >
                <div className="flex items-center gap-4 flex-1">
                  <IconComponent className={`w-6 h-6 ${iconColor}`} />
                  <div>
                    <div className="font-medium text-gray-900">
                      {formatDate(day.date, index)}
                    </div>
                    <div className="text-sm text-gray-600">{currentConditions}</div>
                  </div>
                </div>
                
                <div className="flex items-center gap-6 text-right">
                  <div className="text-sm">
                    <div className="text-blue-600 font-medium">
                      {/* Provide default 0 for precipitation_chance if undefined */}
                      {day.precipitation_chance || 0}%
                    </div>
                    <div className="text-xs text-gray-500">Rain</div>
                  </div>
                  
                  <div className="text-sm">
                    <div className="text-gray-600 font-medium">
                      {/* Provide default 0 for wind_speed if undefined */}
                      {day.wind_speed || 0} mph
                    </div>
                    <div className="text-xs text-gray-500">Wind</div>
                  </div>
                  
                  <div className="text-right">
                    <div className="font-bold text-gray-900">
                      {/* Provide default 0 for high_temp if undefined */}
                      {Math.round(day.high_temp || 0)}°
                    </div>
                    <div className="text-sm text-gray-500">
                      {/* Provide default 0 for low_temp if undefined */}
                      {Math.round(day.low_temp || 0)}°
                    </div>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </CardContent>
    </Card>
  );
}
