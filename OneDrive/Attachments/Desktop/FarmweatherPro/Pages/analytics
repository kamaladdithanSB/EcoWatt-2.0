
import React, { useState, useEffect, useCallback } from "react";
import { InvokeLLM } from "@/integrations/Core";
import { Location } from "@/entities/Location";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from "@/components/ui/select";
import { Skeleton } from "@/components/ui/skeleton";
import { BarChart, Bar, XAxis, YAxis, CartesianGrid, Tooltip, ResponsiveContainer, LineChart, Line } from "recharts";
import { TrendingUp, Droplets, Thermometer, Wind } from "lucide-react";
import { format } from "date-fns"; // Import format from date-fns

export default function Analytics() {
  const [locations, setLocations] = useState([]);
  const [selectedLocation, setSelectedLocation] = useState(null);
  const [analyticsData, setAnalyticsData] = useState(null);
  const [isLoading, setIsLoading] = useState(false);

  useEffect(() => {
    loadLocations();
  }, []);

  const formatChartDate = (dateString) => {
    try {
      if (!dateString) return '';
      const date = new Date(dateString);
      if (isNaN(date.getTime())) {
        // If date parsing failed, return the original string or a fallback
        console.warn(`Invalid date string encountered: "${dateString}"`);
        return dateString;
      }
      return format(date, 'MMM dd');
    } catch (error) {
      console.warn('Chart date formatting error:', error, 'for date string:', dateString);
      return dateString; // Return original string on error
    }
  };

  const processChartData = (data, dateKey) => {
    if (!data || !Array.isArray(data)) return [];
    return data.map(item => {
      const newItem = { ...item };
      if (newItem[dateKey]) {
        newItem[dateKey] = formatChartDate(newItem[dateKey]);
      }
      return newItem;
    });
  };

  const loadLocations = async () => {
    try {
      const fetchedLocations = await Location.list();
      setLocations(fetchedLocations);
      if (fetchedLocations.length > 0) {
        const primary = fetchedLocations.find(loc => loc.is_primary) || fetchedLocations[0];
        setSelectedLocation(primary);
      }
    } catch (error) {
      console.error("Error loading locations:", error);
    }
  };

  const loadAnalytics = useCallback(async () => {
    if (!selectedLocation) return;

    setIsLoading(true);
    try {
      const analyticsPrompt = `Provide weather analytics and historical data for farming at location: ${selectedLocation.address}. 
      Include 30-day historical temperature, rainfall, and growing degree days trends. 
      Also provide seasonal patterns, optimal planting windows, and weather-based farming recommendations.
      Format data suitable for charts and agricultural planning.`;

      const result = await InvokeLLM({
        prompt: analyticsPrompt,
        add_context_from_internet: true,
        response_json_schema: {
          type: "object",
          properties: {
            temperature_trend: {
              type: "array",
              items: {
                type: "object",
                properties: {
                  date: { type: "string" },
                  avg_temp: { type: "number" },
                  high_temp: { type: "number" },
                  low_temp: { type: "number" }
                }
              }
            },
            rainfall_data: {
              type: "array",
              items: {
                type: "object",
                properties: {
                  date: { type: "string" },
                  rainfall: { type: "number" }
                }
              }
            },
            growing_degree_days: {
              type: "array",
              items: {
                type: "object",
                properties: {
                  date: { type: "string" },
                  gdd: { type: "number" }
                }
              }
            },
            summary_stats: {
              type: "object",
              properties: {
                avg_temperature: { type: "number" },
                total_rainfall: { type: "number" },
                total_gdd: { type: "number" },
                optimal_planting_window: { type: "string" }
              }
            },
            recommendations: {
              type: "array",
              items: { type: "string" }
            }
          }
        }
      });

      setAnalyticsData(result);
    } catch (error) {
      console.error("Error loading analytics:", error);
    }
    setIsLoading(false);
  }, [selectedLocation]);

  useEffect(() => {
    if (selectedLocation) {
      loadAnalytics();
    }
  }, [selectedLocation, loadAnalytics]);

  if (locations.length === 0) {
    return (
      <div className="min-h-screen flex items-center justify-center p-6">
        <Card className="max-w-md w-full text-center">
          <CardContent className="pt-6">
            <p className="text-gray-600">Add farm locations to view analytics.</p>
          </CardContent>
        </Card>
      </div>
    );
  }

  return (
    <div className="min-h-screen p-4 md:p-6">
      <div className="max-w-7xl mx-auto space-y-6">
        <div className="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
          <div>
            <h1 className="text-3xl font-bold text-gray-900">Weather Analytics</h1>
            <p className="text-gray-600 mt-1">Historical weather data and trends for agricultural planning</p>
          </div>
          
          <Select
            value={selectedLocation?.id || ""}
            onValueChange={(value) => {
              const location = locations.find(loc => loc.id === value);
              setSelectedLocation(location);
            }}
          >
            <SelectTrigger className="w-48">
              <SelectValue placeholder="Select location" />
            </SelectTrigger>
            <SelectContent>
              {locations.map((location) => (
                <SelectItem key={location.id} value={location.id}>
                  {location.name}
                </SelectItem>
              ))}
            </SelectContent>
          </Select>
        </div>

        {isLoading ? (
          <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
            {Array(4).fill(0).map((_, i) => (
              <Card key={i}>
                <CardHeader>
                  <Skeleton className="h-6 w-48" />
                </CardHeader>
                <CardContent>
                  <Skeleton className="h-64 w-full" />
                </CardContent>
              </Card>
            ))}
          </div>
        ) : analyticsData ? (
          <>
            {/* Summary Stats */}
            <div className="grid grid-cols-1 md:grid-cols-4 gap-4">
              <Card>
                <CardContent className="p-6">
                  <div className="flex items-center gap-3">
                    <Thermometer className="w-8 h-8 text-orange-600" />
                    <div>
                      <p className="text-sm text-gray-600">Avg Temperature</p>
                      <p className="text-2xl font-bold text-gray-900">
                        {Math.round(analyticsData.summary_stats.avg_temperature)}°F
                      </p>
                    </div>
                  </div>
                </CardContent>
              </Card>

              <Card>
                <CardContent className="p-6">
                  <div className="flex items-center gap-3">
                    <Droplets className="w-8 h-8 text-blue-600" />
                    <div>
                      <p className="text-sm text-gray-600">Total Rainfall</p>
                      <p className="text-2xl font-bold text-gray-900">
                        {analyticsData.summary_stats.total_rainfall}"
                      </p>
                    </div>
                  </div>
                </CardContent>
              </Card>

              <Card>
                <CardContent className="p-6">
                  <div className="flex items-center gap-3">
                    <TrendingUp className="w-8 h-8 text-green-600" />
                    <div>
                      <p className="text-sm text-gray-600">Growing Degree Days</p>
                      <p className="text-2xl font-bold text-gray-900">
                        {Math.round(analyticsData.summary_stats.total_gdd)}
                      </p>
                    </div>
                  </div>
                </CardContent>
              </Card>

              <Card>
                <CardContent className="p-6">
                  <div className="flex items-center gap-3">
                    <Wind className="w-8 h-8 text-purple-600" />
                    <div>
                      <p className="text-sm text-gray-600">Planting Window</p>
                      <p className="text-sm font-bold text-gray-900">
                        {analyticsData.summary_stats.optimal_planting_window}
                      </p>
                    </div>
                  </div>
                </CardContent>
              </Card>
            </div>

            {/* Charts */}
            <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
              <Card>
                <CardHeader>
                  <CardTitle>Temperature Trends (30 Days)</CardTitle>
                </CardHeader>
                <CardContent>
                  <ResponsiveContainer width="100%" height={300}>
                    <LineChart data={processChartData(analyticsData.temperature_trend, 'date')}>
                      <CartesianGrid strokeDasharray="3 3" />
                      <XAxis dataKey="date" />
                      <YAxis />
                      <Tooltip />
                      <Line type="monotone" dataKey="high_temp" stroke="#f59e0b" name="High" />
                      <Line type="monotone" dataKey="avg_temp" stroke="#10b981" name="Average" />
                      <Line type="monotone" dataKey="low_temp" stroke="#3b82f6" name="Low" />
                    </LineChart>
                  </ResponsiveContainer>
                </CardContent>
              </Card>

              <Card>
                <CardHeader>
                  <CardTitle>Rainfall Distribution</CardTitle>
                </CardHeader>
                <CardContent>
                  <ResponsiveContainer width="100%" height={300}>
                    <BarChart data={processChartData(analyticsData.rainfall_data, 'date')}>
                      <CartesianGrid strokeDasharray="3 3" />
                      <XAxis dataKey="date" />
                      <YAxis />
                      <Tooltip />
                      <Bar dataKey="rainfall" fill="#3b82f6" />
                    </BarChart>
                  </ResponsiveContainer>
                </CardContent>
              </Card>
            </div>

            {/* Growing Degree Days Chart */}
            <Card>
              <CardHeader>
                <CardTitle>Growing Degree Days Accumulation</CardTitle>
              </CardHeader>
              <CardContent>
                <ResponsiveContainer width="100%" height={300}>
                  <LineChart data={processChartData(analyticsData.growing_degree_days, 'date')}>
                    <CartesianGrid strokeDasharray="3 3" />
                    <XAxis dataKey="date" />
                    <YAxis />
                    <Tooltip />
                    <Line type="monotone" dataKey="gdd" stroke="#10b981" strokeWidth={3} />
                  </LineChart>
                </ResponsiveContainer>
              </CardContent>
            </Card>

            {/* Recommendations */}
            <Card>
              <CardHeader>
                <CardTitle>Agricultural Recommendations</CardTitle>
              </CardHeader>
              <CardContent>
                <div className="space-y-3">
                  {analyticsData.recommendations.map((recommendation, index) => (
                    <div key={index} className="p-4 bg-green-50 rounded-lg border-l-4 border-green-500">
                      <p className="text-gray-800">{recommendation}</p>
                    </div>
                  ))}
                </div>
              </CardContent>
            </Card>
          </>
        ) : (
          <div className="text-center py-12">
            <Button onClick={loadAnalytics} className="bg-green-600 hover:bg-green-700">
              Load Analytics Data
            </Button>
          </div>
        )}
      </div>
    </div>
  );
}
